# CityWater backend environment variables.
# Copy to backend/.env for local development. Do not commit .env.

ENVIRONMENT=development
SECRET_KEY=dev-secret-do-not-use-in-prod
DATABASE_URL=postgresql+psycopg://citywater:citywater@localhost:5432/citywater
GIT_SHA=dev
LOG_LEVEL=INFO

# Used by tests (pytest-postgresql noproc factory).
PGHOST=localhost
PGPORT=5432
PGUSER=citywater
PGPASSWORD=citywater
