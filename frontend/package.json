{
  "name": "flowops-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-api": "openapi-typescript http://localhost:5000/api/v1/openapi.json -o src/api/generated.ts"
  },
  "_dependencyJustifications": {
    "react": "UI framework (CLAUDE.md mandate: React 18)",
    "react-dom": "DOM renderer for React",
    "react-router-dom": "client routing — used in S2+ for /{slug}/... routes (CLAUDE.md repo layout)",
    "@tanstack/react-query": "server state management (CLAUDE.md mandate)",
    "@types/react": "React types for strict TS",
    "@types/react-dom": "react-dom types",
    "@vitejs/plugin-react": "JSX/HMR support for Vite",
    "typescript": "strict TS toolchain (CLAUDE.md mandate)",
    "vite": "dev server + bundler (CLAUDE.md mandate)",
    "tailwindcss": "styling (CLAUDE.md mandate; only styling tool allowed)",
    "postcss": "Tailwind requires PostCSS pipeline",
    "autoprefixer": "vendor-prefix CSS for older browsers",
    "eslint": "lint (CLAUDE.md mandate)",
    "@typescript-eslint/eslint-plugin": "TS-aware lint rules",
    "@typescript-eslint/parser": "TS parser for ESLint",
    "eslint-plugin-react-hooks": "rules-of-hooks enforcement",
    "eslint-plugin-react-refresh": "HMR safety lint",
    "prettier": "formatter (CLAUDE.md mandate)",
    "vitest": "test runner (CLAUDE.md mandate)",
    "@testing-library/react": "RTL for component tests (CLAUDE.md mandate)",
    "@testing-library/jest-dom": "DOM matchers for Vitest",
    "@testing-library/user-event": "user interaction simulation in component tests (CLAUDE.md test requirement)",
    "jsdom": "DOM environment for vitest",
    "openapi-typescript": "generates frontend types from backend OpenAPI spec (CLAUDE.md TS rule, S2+)"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.40.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^24.0.0",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
